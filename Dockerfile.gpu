# GPU image: bundles torch/CUDA (from the base) + transformers for the local
# vision-LLM OCR backend. Larger than the default CPU image; build only when
# you have an NVIDIA GPU + NVIDIA Container Toolkit on the host.
#
# torch 2.6.0 (not 2.4.1): autoawq-kernels requires torch>=2.5.1 (see
# requirements-gpu.txt for the transformers/autoawq version story). Stays on
# CUDA 12.4 — the CUDA-13 requirement that ruled out newer torch only appears
# at torch>=2.7.1.
FROM pytorch/pytorch:2.6.0-cuda12.4-cudnn9-runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
        tesseract-ocr tesseract-ocr-deu \
        libgl1 libglib2.0-0 \
        build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt requirements-gpu.txt ./
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir -r requirements-gpu.txt

COPY app ./app

# Model weights are cached here; mount a volume to persist across runs and to
# support fully-offline operation after a one-time download.
ENV HF_HOME=/models
ENV OCR_BACKEND=vlm

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
